{
  "name": "@sell-direct/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@sell-direct/shared": "workspace:*",
    "fastify": "^5.2.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "^2.1.8"
  }
}
