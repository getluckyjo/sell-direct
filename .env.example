# ──────────────────────────────────────────────────────────────
# Sell Direct — environment template
# Copy to .env and fill with SANDBOX / TEST values only.
# NEVER commit real secrets. .env is gitignored.
# Keep this file in sync whenever a new config key is added.
# ──────────────────────────────────────────────────────────────

# --- API server ---
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (PostgreSQL / Supabase) — used from PR 2 (Prisma) ---
# Two URLs:
#   DATABASE_URL — runtime/pooled connection (Supabase pgBouncer, port 6543, add ?pgbouncer=true)
#   DIRECT_URL   — direct connection for migrations (Supabase, port 5432)
# Local dev: run a throwaway Postgres and point BOTH at it (no Supabase needed):
#   docker run -d --name selldirect-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:dev@localhost:5432/sell_direct?schema=public
DIRECT_URL=postgresql://postgres:dev@localhost:5432/sell_direct?schema=public
# Deploy (Supabase) example — set these in the host dashboard, never in the repo:
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Supabase (managed Auth + Storage) — Auth used from PR 6, Storage when uploads land ---
# Service-role key is SERVER-SIDE ONLY — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public (browser) values for the web dashboard auth:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- WhatsApp Business Platform (Cloud API via BSP) — used from PR 3 ---
# Sandbox/test values only.
WHATSAPP_VERIFY_TOKEN=replace-with-your-own-random-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
# Graph API endpoint (override if a BSP proxies the Cloud API).
WHATSAPP_API_VERSION=v21.0
WHATSAPP_GRAPH_BASE=https://graph.facebook.com

# --- Bond originator referral (ooba) — used from PR 5 ---
# The hand-off is stubbed until a real partner integration is approved.
ORIGINATOR_REFERRAL_ENDPOINT=
ORIGINATOR_API_KEY=

# --- Encryption (POPIA: encrypt sensitive fields at rest) — used from PR 2 ---
# 32-byte key, base64-encoded. Generate locally; never commit a real key.
FIELD_ENCRYPTION_KEY=

# --- Web dashboard ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
